```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python related (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
.pytest_cache/
.mypy_cache/

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
```